{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AviationHub",
  "version": "1.0.0",
  "identifier": "com.aviationhub.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000/desktop",
    "beforeDevCommand": "echo dev server already running",
    "beforeBuildCommand": "node scripts/build-tauri.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AviationHub",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null,
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "wix": {
        "language": "en-US"
      }
    },
    "licenseFile": "../LICENSE"
  },
  "plugins": {
    "sql": {
      "default": "sqlite:aviationhub.db"
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/masterkoster/next-dashboard/releases/latest/download/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1MDQ1MzQzQzQyOTI1NUMKUldSY0pTbkVRMU1FOVEwdVFGUjFqdW1CKytMSkJ6SjBmd05qUHV4MHZOY1pzaW5ERnlLRmhYUjMK"
    }
  }
}
