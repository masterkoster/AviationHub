# Environment variables for Vercel deployment

# Prisma Database
DATABASE_URL="sqlserver://your-server.database.windows.net:1433;database=your-db;user=your-user;password=your-password;encrypt=true;trustServerCertificate=false;loginTimeout=30;"
PRISMA_CLIENT_ENGINE_TYPE="binary"

# TailHistory / Plane Carfax Azure Function
NEXT_PUBLIC_TAILHISTORY_FUNCTION_URL="https://your-function.azurewebsites.net/api/tailhistory"

# NextAuth - Generate a random secret with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# Google Analytics - Get your Measurement ID from https://analytics.google.com
# Starts with G- (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Stripe Connect (club payments) - see docs/PAYMENTS.md for the full setup.
# Secret key for the platform account (sk_test_... in dev). Clubs still hold their own funds.
STRIPE_SECRET_KEY=
# Signing secret for the /api/stripe/webhook endpoint (whsec_...); register the endpoint to LISTEN TO CONNECTED ACCOUNTS.
STRIPE_WEBHOOK_SECRET=
# Publishable key for the platform account (pk_test_... in dev), safe to expose client-side.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
