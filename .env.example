# Environment variables for Vercel deployment

# Prisma Database
DATABASE_URL="sqlserver://your-server.database.windows.net:1433;database=your-db;user=your-user;password=your-password;encrypt=true;trustServerCertificate=false;loginTimeout=30;"
PRISMA_CLIENT_ENGINE_TYPE="binary"

# TailHistory / Plane Carfax Azure Function
NEXT_PUBLIC_TAILHISTORY_FUNCTION_URL="https://your-function.azurewebsites.net/api/tailhistory"

# NextAuth - Generate a random secret with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# Google Analytics - Get your Measurement ID from https://analytics.google.com
# Starts with G- (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Stripe Connect (club payments) - see docs/PAYMENTS.md for the full setup.
# Secret key for the platform account (sk_test_... in dev). Clubs still hold their own funds.
STRIPE_SECRET_KEY=
# Signing secret for the /api/stripe/webhook endpoint (whsec_...); register the endpoint to LISTEN TO CONNECTED ACCOUNTS.
STRIPE_WEBHOOK_SECRET=
# Publishable key for the platform account (pk_test_... in dev), safe to expose client-side.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Sentry error monitoring - see docs/MONITORING.md. Everything below is optional;
# Sentry stays fully inert (no-op init) until NEXT_PUBLIC_SENTRY_DSN is set.
# DSN from your Sentry project settings (Client Keys). Safe to expose client-side.
NEXT_PUBLIC_SENTRY_DSN=
# Sentry org slug, only needed for source map upload during build.
SENTRY_ORG=
# Sentry project slug, only needed for source map upload during build.
SENTRY_PROJECT=
# Sentry auth token (from https://sentry.io/settings/account/api/auth-tokens/), only needed for source map upload during build.
SENTRY_AUTH_TOKEN=

# Shared secret for the scheduled billing job (/api/cron/billing). Generate
# with `openssl rand -base64 32`; set the same value as a repo secret
# (CRON_SECRET) alongside APP_BASE_URL for .github/workflows/billing-cron.yml.
# The endpoint returns 503 while this is unset.
CRON_SECRET=

# QuickBooks Online (sandbox). Create an app at developer.intuit.com; see docs/QUICKBOOKS.md
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
